---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<Layout title="Blog — sinibaca" description="Semua artikel di sinibaca">
  <div class="home-header">
    <h1 class="page-title">Semua Artikel</h1>
    <p class="page-subtitle">{sortedPosts.length} artikel ditemukan</p>
  </div>
  <div class="posts-grid">
    {sortedPosts.map((post, index) => (
      <div class="post-animate" style={`animation-delay: ${index * 80}ms`}>
        <PostCard post={post} />
      </div>
    ))}
  </div>
</Layout>

<style>
  .home-header {
    margin-bottom: 32px;
  }
  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
    color: var(--text);
  }
  .page-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
  }
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .post-animate {
    opacity: 0;
    animation: fadeSlideUp 0.5s ease forwards;
  }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
