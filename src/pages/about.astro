---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Tentang — sinibaca" description="Tentang blog sinibaca">
  <div class="about-page">
    <h1>Tentang sinibaca</h1>
    <p>
      <strong>sinibaca</strong> adalah blog modern yang dibangun dengan 
      <a href="https://astro.build" target="_blank">Astro</a> dan 
      <a href="https://tailwindcss.com" target="_blank">Tailwind CSS</a>.
    </p>
    <p>
      Blog ini berisi kumpulan artikel tentang teknologi, tutorial, filsafat, 
      dan catatan pengembangan web.
    </p>
    <h2>Teknologi</h2>
    <ul>
      <li>Astro v6.4.6 — Framework web modern</li>
      <li>Tailwind CSS v4 — Utility-first CSS</li>
      <li>Markdown + MDX — Content authoring</li>
      <li>GitHub Pages — Hosting gratis</li>
    </ul>
    <h2>Kontak</h2>
    <p>
      <a href="https://github.com/riskipriyadi" target="_blank">GitHub</a> · 
      <a href="https://twitter.com" target="_blank">Twitter</a>
    </p>
  </div>
</Layout>

<style>
  .about-page {
    animation: fadeInUp 0.5s ease;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .about-page h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    color: var(--text);
  }
  .about-page h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 32px;
    margin-bottom: 12px;
    color: var(--text);
  }
  .about-page p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 16px;
  }
  .about-page a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .about-page ul {
    padding-left: 24px;
    margin-bottom: 20px;
  }
  .about-page li {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
</style>
