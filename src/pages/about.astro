---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Tentang sinibaca" description="Nulis kalau semua kondisi mendukung, dan itu jarang terjadi.">
  <div class="about-page">
    <h1>Tentang sinibaca</h1>
    
    <p class="tagline">Nulis kalau semua kondisi mendukung, dan itu jarang terjadi. Tidak asal tulis, ada referensi di balik setiap kalimat.</p>
    
    <div class="about-section">
      <h2>Sosial</h2>
      <a href="https://instagram.com/sinibaca" target="_blank" rel="noopener noreferrer" class="social-link">
        <img src={`${base}instagram-icon.png`} alt="Instagram" width="25.5" height="25.5" style="display:block;" />
        Instagram
      </a>
    </div>
  </div>
</Layout>

<style>
  .about-page {
    max-width: 600px;
  }
  
  .about-page h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--text, #0f172a);
  }
  
  .tagline {
    font-size: 1rem;
    color: var(--text-secondary, #475569);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }
  
  .about-section h2 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted, #94a3b8);
    margin-bottom: 0.75rem;
  }
  
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text, #0f172a);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 8px;
    transition: all 0.2s ease;
    border: 1px solid transparent;
    position: relative;
  }
  .social-link::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent, #6366f1);
    opacity: 1;
    transition: opacity 0.3s ease;
    border-radius: 8px 0 0 8px;
  }
  
  .social-link:hover {
    background: var(--bg-secondary, #f8fafc);
    color: var(--accent, #6366f1);
    border-color: var(--border, #e2e8f0);
  }
  
  .social-link img {
    flex-shrink: 0;
  }
</style>