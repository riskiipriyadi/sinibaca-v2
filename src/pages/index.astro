---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const base = import.meta.env.BASE_URL;
const postsPerPage = 6;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
---

<Layout title="Beranda" description="Kumpulan tulisan dan catatan">
  <div class="home-header">
    <h1 class="page-title">Sinibaca</h1>
    <p class="page-subtitle">Kumpulan tulisan, catatan, dan dokumentasi</p>
  </div>

  <div class="posts-list" id="posts-list" data-total-pages={totalPages}>
    {sortedPosts.map((post, index) => {
      const page = Math.floor(index / postsPerPage) + 1;

      // FIX: Handle absolute URL, relative path, dan missing thumbnail
      const thumb = post.data.thumbnail || post.data.heroImage;
      let imageUrl;
      if (!thumb) {
        imageUrl = base + 'images/placeholder.jpg';
      } else if (thumb.startsWith('http')) {
        imageUrl = thumb;
      } else if (thumb.startsWith('/')) {
        imageUrl = base + thumb.slice(1);
      } else {
        imageUrl = base + thumb;
      }

      // FIX: Fallback slug untuk link
      const slug = post.slug || post.id.split('/').pop()?.replace(/\.mdx?$/, '');

      const dateStr = post.data.pubDate.toLocaleDateString("id-ID", {
        year: "numeric",
        month: "short",
        day: "numeric"
      });

      return (
        <div class={`post-item ${page !== 1 ? 'hidden' : ''}`} data-page={page}>
          <a href={`${base}blog/${slug}`} class="post-card">
            <div class="post-thumb-wrap">
              <img 
                src={imageUrl} 
                alt={post.data.title} 
                class="post-thumb" 
                loading="lazy" 
                onerror={`this.src='${base}images/placeholder.jpg'`}
              />
            </div>
            <div class="post-body">
              <div class="post-meta">
                <span class="post-cat">{post.data.category || "Uncategorized"}</span>
                <span class="post-date">{dateStr}</span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
            </div>
          </a>
        </div>
      );
    })}
  </div>

  {totalPages > 1 && (
    <div class="pagination" id="pagination">
      <button class="page-btn" id="prev-btn" disabled>← Prev</button>
      <span class="page-info" id="page-info">1 / {totalPages}</span>
      <button class="page-btn" id="next-btn">Next →</button>
    </div>
  )}
</Layout>

<style>
  .home-header {
    margin-bottom: 16px;
  }
  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 6px;
    color: var(--text);
  }
  .page-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
  }
  .posts-list {
    display: grid;
    gap: 16px;
  }
  .post-item.hidden {
    display: none;
  }
  .post-card {
    display: flex;
    gap: 16px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }
  .post-card:hover {
    border-color: var(--accent);
  }
  .post-thumb-wrap {
    flex-shrink: 0;
    width: 120px;
    height: 80px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--code-bg);
  }
  .post-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-body {
    flex: 1;
    min-width: 0;
  }
  .post-meta {
    display: flex;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .post-cat {
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 500;
    color: var(--accent);
  }
  .post-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 6px;
    line-height: 1.3;
    color: var(--text);
  }
  .post-excerpt {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .page-btn {
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--text);
    cursor: pointer;
    font-size: 0.875rem;
  }
  .page-btn:hover:not(:disabled) {
    border-color: var(--accent);
  }
  .page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .page-info {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
</style>

<script>
  // Client-side pagination logic
  const postsList = document.getElementById('posts-list');
  const pagination = document.getElementById('pagination');
  if (postsList && pagination) {
    const totalPages = parseInt(postsList.dataset.totalPages, 10);
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const pageInfo = document.getElementById('page-info');
    let currentPage = 1;

    function showPage(page) {
      document.querySelectorAll('.post-item').forEach(item => {
        item.classList.toggle('hidden', parseInt(item.dataset.page, 10) !== page);
      });
      currentPage = page;
      if (pageInfo) pageInfo.textContent = `${page} / ${totalPages}`;
      if (prevBtn) prevBtn.disabled = page === 1;
      if (nextBtn) nextBtn.disabled = page === totalPages;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    prevBtn?.addEventListener('click', () => showPage(currentPage - 1));
    nextBtn?.addEventListener('click', () => showPage(currentPage + 1));
  }
</script>
