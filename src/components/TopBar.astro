---
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = await getCollection("blog", ({ data }) => !data.draft);
const postsData = posts.map(p => ({
  title: p.data.title,
  slug: p.id,
  description: p.data.description || "",
  category: p.data.category || "Uncategorized",
  thumbnail: p.data.thumbnail || p.data.heroImage || ""
}));
---

<header class="topbar">
  <div class="topbar-inner">
    <a href={`${base}/`} class="logo">
      <img src={`${base}/favicons/favicon-32x32.png`} alt="sinibaca" class="logo-img" width="28" height="28" />
      <span class="logo-text">sinibaca</span>
    </a>

    <div class="search-bar" data-posts={JSON.stringify(postsData)}>
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" placeholder="Cari artikel..." class="search-input" id="search-input" autocomplete="off" />
      <div class="search-dropdown" id="search-dropdown"></div>
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const sidebar = document.querySelector(".sidebar-left");
  toggle?.addEventListener("click", () => {
    sidebar?.classList.toggle("mobile-open");
  });

  // Real-time search
  const searchBar = document.querySelector('.search-bar');
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchDropdown = document.getElementById('search-dropdown') as HTMLElement | null;
  
  if (searchBar && searchInput && searchDropdown) {
    const posts = JSON.parse((searchBar as HTMLElement).dataset.posts || '[]');
    const base = window.location.pathname.startsWith('/sinibaca-v2') ? '/sinibaca-v2' : '';
    
    function escapeRegex(str: string) {
      return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }
    
    function highlightText(text: string, query: string) {
      if (!query) return text;
      const regex = new RegExp(`(${escapeRegex(query)})`, 'gi');
      return text.replace(regex, '<mark>$1</mark>');
    }
    
    function renderResults(results: any[], query: string) {
      if (!searchDropdown) return;
      
      if (results.length === 0) {
        searchDropdown.innerHTML = `
          <div class="search-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.35;margin-bottom:8px;">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <div style="font-size:0.8125rem;color:var(--text-muted);">Tidak ada hasil untuk "<strong style="color:var(--text);font-weight:600;">${query}</strong>"</div>
          </div>
        `;
        return;
      }
      
      searchDropdown.innerHTML = results.map(post => {
        const thumb = post.thumbnail ? `${base}${post.thumbnail}` : `${base}/favicons/favicon-32x32.png`;
        const hasDesc = post.description && post.description.trim().length > 0;
        return `
          <a href="${base}/blog/${post.slug}" class="search-result-item">
            <img src="${thumb}" alt="" class="search-thumb" loading="lazy" onerror="this.style.display='none'" />
            <div class="search-result-body">
              <div class="search-result-meta">
                <span class="search-category">${post.category}</span>
              </div>
              <div class="search-title">${highlightText(post.title, query)}</div>
              ${hasDesc ? `<div class="search-desc">${highlightText(post.description, query)}</div>` : ''}
            </div>
          </a>
        `;
      }).join('');
    }
    
    function debounce(func: Function, wait: number) {
      let timeout: ReturnType<typeof setTimeout>;
      return function executedFunction(...args: any[]) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    }
    
    const handleSearch = debounce((e: Event) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      
      if (!query) {
        if (searchDropdown) {
          searchDropdown.innerHTML = '';
          searchDropdown.classList.remove('active');
        }
        return;
      }
      
      const results = posts.filter((post: any) => 
        post.title.toLowerCase().includes(query) || 
        post.description.toLowerCase().includes(query) ||
        post.category.toLowerCase().includes(query)
      ).slice(0, 10);
      
      renderResults(results, query);
      if (searchDropdown) {
        searchDropdown.classList.add('active');
      }
    }, 200);
    
    searchInput.addEventListener('input', handleSearch);
    
    document.addEventListener('click', (e) => {
      if (!searchBar.contains(e.target as Node)) {
        searchDropdown?.classList.remove('active');
      }
    });
    
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchDropdown?.classList.remove('active');
        searchInput.blur();
      }
    });
    
    searchInput.addEventListener('focus', () => {
      if (searchInput.value.trim().length > 0 && searchDropdown && searchDropdown.innerHTML.trim().length > 0) {
        searchDropdown.classList.add('active');
      }
    });
  }
</script>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--bg, #ffffff);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border, #e2e8f0);
    z-index: 100;
  }
  
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    gap: 16px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--text, #0f172a);
    font-weight: 700;
    font-size: 1.125rem;
    flex-shrink: 0;
  }
  
  .logo-img {
    border-radius: 6px;
  }
  
  .search-bar {
    position: relative;
    flex: 1;
    max-width: 400px;
    min-width: 200px;
  }
  
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted, #94a3b8);
    pointer-events: none;
    z-index: 2;
  }
  
  .search-input {
    width: 100%;
    height: 40px;
    padding: 0 12px 0 40px;
    border-radius: 10px;
    border: 1px solid transparent;
    background: var(--bg-secondary, #f8fafc);
    color: var(--text, #0f172a);
    font-size: 0.875rem;
    font-family: inherit;
    transition: all 0.2s ease;
  }
  
  .search-input::placeholder {
    color: var(--text-muted, #94a3b8);
  }
  
  .search-input:focus {
    outline: none;
    background: var(--bg, #ffffff);
    border-color: var(--accent, #6366f1);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
  }
  
  /* === DROPDOWN: HUGGINGFACE STYLE === */
  .search-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 420px;
    max-width: calc(100vw - 32px);
    background: var(--bg, #ffffff);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 12px;
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.08), 0 8px 10px -6px rgba(0,0,0,0.04);
    max-height: 420px;
    overflow-y: auto;
    overflow-x: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: all 0.18s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 200;
  }
  
  .search-dropdown.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  
  .search-dropdown::-webkit-scrollbar {
    width: 5px;
  }
  .search-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }
  .search-dropdown::-webkit-scrollbar-thumb {
    background: var(--border, #e2e8f0);
    border-radius: 3px;
  }
  
  /* Result item - HuggingFace row style */
  .search-result-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    text-decoration: none !important;
    border-bottom: 1px solid var(--border, #e2e8f0);
    transition: background-color 0.12s ease;
    cursor: pointer;
    color: inherit;
  }
  
  .search-result-item:last-child {
    border-bottom: none;
  }
  
  .search-result-item:hover {
    background-color: var(--bg-secondary, #f8fafc);
  }
  
  .search-result-item:hover .search-title {
    color: var(--accent, #6366f1);
  }
  
  /* Thumbnail: 36x36 compact rounded */
  .search-thumb {
    width: 36px;
    height: 36px;
    min-width: 36px;
    border-radius: 6px;
    object-fit: cover;
    display: block;
    background: var(--bg-secondary, #f8fafc);
  }
  
  /* Body: flex-1 with min-width:0 is CRITICAL for text-overflow to work */
  .search-result-body {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }
  
  .search-result-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 3px;
  }
  
  .search-category {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--accent, #6366f1);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
  }
  
  /* Title: single line, truncate, NO underline ever */
  .search-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text, #0f172a);
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
  }
  
  .search-title mark {
    background: rgba(99, 102, 241, 0.18);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 700;
  }
  
  /* Description: single line muted */
  .search-desc {
    font-size: 0.75rem;
    color: var(--text-muted, #94a3b8);
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }
  
  .search-desc mark {
    background: rgba(99, 102, 241, 0.12);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }
  
  /* Empty state */
  .search-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
    text-align: center;
  }
  
  /* Menu toggle */
  .menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    color: var(--text, #0f172a);
    cursor: pointer;
    border-radius: 8px;
    transition: background 0.2s ease;
  }
  
  .menu-toggle:hover {
    background: var(--bg-secondary, #f8fafc);
  }
  
  @media (max-width: 768px) {
    .topbar-inner {
      padding: 0 16px;
    }
    
    .search-bar {
      max-width: none;
    }
    
    .search-dropdown {
      position: fixed;
      top: 66px;
      left: 16px;
      right: 16px;
      width: auto;
    }
    
    .menu-toggle {
      display: flex;
    }
  }
</style>