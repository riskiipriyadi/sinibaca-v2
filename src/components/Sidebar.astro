---
import { getCollection } from "astro:content";
import avatarImg from "../assets/avatar.png";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const categoryCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  const cat = post.data.category || "Uncategorized";
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
});
const categories = Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]);

const yearCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  const year = new Date(post.data.pubDate).getFullYear().toString();
  yearCounts[year] = (yearCounts[year] || 0) + 1;
});
const years = Object.entries(yearCounts).sort((a, b) => Number(b[0]) - Number(a[0]));

const navItems = [
  { label: "Beranda", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "Tentang", href: "/about" },
];
const socials = [
  { label: "GitHub", href: "https://github.com/riskipriyadi" },
  { label: "Twitter/X", href: "https://twitter.com" },
];
---

<div class="sidebar">
  <!-- Profile -->
  <div class="profile-card">
    <img
      src={avatarImg.src}
      alt="sinibaca"
      class="avatar"
      width="72"
      height="72"
    />
    <h3 class="name">sinibaca</h3>
    <p class="bio">Blog modern dengan Astro &amp; Tailwind</p>
    <div class="stats">
      <div class="stat"><span class="stat-val">{allPosts.length}</span><span class="stat-lbl">Artikel</span></div>
      <div class="stat"><span class="stat-val">{Object.keys(categoryCounts).length}</span><span class="stat-lbl">Kategori</span></div>
    </div>
  </div>

  <!-- Navigasi -->
  <div class="section-card">
    <h4 class="section-title">Navigasi</h4>
    <nav class="nav-list">
      {navItems.map((item) => (
        <a href={item.href} class="nav-item">{item.label}</a>
      ))}
    </nav>
  </div>

  <!-- Kategori -->
  <div class="section-card">
    <h4 class="section-title">Kategori</h4>
    <div class="cat-list">
      {categories.map(([cat, count]) => (
        <a href="/blog" class="cat-item">
          <span>{cat}</span>
          <span class="badge">{count}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Arsip -->
  <div class="section-card">
    <h4 class="section-title">Arsip</h4>
    <div class="cat-list">
      {years.map(([year, count]) => (
        <a href="/blog" class="cat-item">
          <span>{year}</span>
          <span class="badge">{count}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Sosial -->
  <div class="section-card">
    <h4 class="section-title">Sosial</h4>
    <div class="social-list">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener" class="social-item">{s.label}</a>
      ))}
    </div>
  </div>

  <!-- Dark Mode -->
  <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
    Mode Gelap
  </button>
</div>

<script>
  const toggle = document.getElementById("theme-toggle");
  const html = document.documentElement;
  
  toggle?.addEventListener("click", () => {
    const isDark = html.getAttribute("data-mode") === "dark";
    const newMode = isDark ? "light" : "dark";
    html.setAttribute("data-mode", newMode);
    localStorage.setItem("theme", newMode);
  });
</script>

<style>
  .sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .profile-card { background: var(--card-bg, #f9f9f9); border: 1px solid var(--border, #e5e7eb); border-radius: 12px; padding: 1.25rem; text-align: center; }
  .avatar { width: 72px; height: 72px; border-radius: 50%; margin: 0 auto 0.5rem; display: block; border: 3px solid var(--accent, #6366f1); }
  .name { font-size: 1rem; font-weight: 700; margin: 0 0 0.25rem; }
  .bio { font-size: 0.75rem; color: var(--muted, #6b7280); margin: 0 0 0.75rem; }
  .stats { display: flex; justify-content: center; gap: 1.5rem; }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-val { font-size: 1.1rem; font-weight: 700; color: var(--accent, #6366f1); }
  .stat-lbl { font-size: 0.7rem; color: var(--muted, #6b7280); }
  .section-card { background: var(--card-bg, #f9f9f9); border: 1px solid var(--border, #e5e7eb); border-radius: 12px; padding: 1rem; }
  .section-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted, #9ca3af); margin: 0 0 0.6rem; }
  .nav-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .nav-item { display: block; padding: 0.4rem 0.6rem; border-radius: 8px; font-size: 0.875rem; text-decoration: none; color: inherit; transition: background 0.15s; }
  .nav-item:hover { background: var(--hover, #f3f4f6); }
  .cat-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .cat-item { display: flex; justify-content: space-between; align-items: center; padding: 0.35rem 0.6rem; border-radius: 8px; font-size: 0.85rem; text-decoration: none; color: inherit; transition: background 0.15s; }
  .cat-item:hover { background: var(--hover, #f3f4f6); }
  .badge { background: var(--accent, #6366f1); color: #fff; font-size: 0.65rem; font-weight: 700; padding: 0.1rem 0.45rem; border-radius: 999px; }
  .social-list { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .social-item { padding: 0.35rem 0.75rem; border: 1px solid var(--border, #e5e7eb); border-radius: 999px; font-size: 0.8rem; text-decoration: none; color: inherit; transition: background 0.15s; }
  .social-item:hover { background: var(--hover, #f3f4f6); }
  .theme-toggle { width: 100%; padding: 0.5rem; border: 1px solid var(--border, #e5e7eb); border-radius: 8px; background: transparent; cursor: pointer; font-size: 0.85rem; transition: background 0.15s; }
  .theme-toggle:hover { background: var(--hover, #f3f4f6); }
</style>